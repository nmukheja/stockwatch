# Required for MongoDB Atlas persistence.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/stockwatch?retryWrites=true&w=majority

# Required for signed JWT sessions. Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me

# Optional escape hatch for environments without the Codex CLI.
# By default Stockwatch attempts live `codex exec` for natural-language inventory answers.
CODEX_DISABLED=false
