# Required for MongoDB Atlas persistence.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/stockwatch?retryWrites=true&w=majority

# Required by NextAuth in production. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me
NEXTAUTH_URL=http://localhost:3000

# Demo login. Defaults are ops@stockwatch.local / codex-demo if omitted.
OPS_DEMO_EMAIL=ops@stockwatch.local
OPS_DEMO_PASSWORD=codex-demo

# Optional: use the real Codex SDK bridge instead of deterministic local reasoning.
# Requires the Codex CLI to be installed and authenticated on the machine running the app.
CODEX_SDK_ENABLED=false
